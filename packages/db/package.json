{
  "name": "@pickup/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "lint": "biome lint .",
    "typecheck": "echo \"@pickup/db typecheck advisory: requires DATABASE_URL and generated client\"",
    "check-types": "pnpm run typecheck",
    "test": "echo \"No package tests for @pickup/db yet\"",
    "db:local": "turso dev --db-file local.db",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "echo \"No seed configured for @pickup/db\""
  },
  "dependencies": {
    "@pickup/env": "workspace:*",
    "@prisma/adapter-libsql": "^7.2.0",
    "@prisma/client": "catalog:",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@pickup/config": "workspace:*",
    "prisma": "^7.2.0",
    "typescript": "catalog:"
  }
}
