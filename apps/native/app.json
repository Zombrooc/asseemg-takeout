{
  "expo": {
    "scheme": "pickup",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "web": {
      "bundler": "metro"
    },
    "name": "ASSEEMG Retira - Mobile",
    "slug": "asseemg-takeout",
    "plugins": [
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir acesso à câmera para escanear o QR de pareamento."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain"
    },
    "android": {
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.asseemg.pickup"
    },
    "ios": {
      "bundleIdentifier": "com.asseemg.pickup"
    },
    "extra": {
      "eas": {
        "projectId": "d05d9a1f-6d8f-4b0a-b763-410253d890cd"
      }
    }
  }
}